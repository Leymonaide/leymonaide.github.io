{% macro render(navigation) %}
    <nav id="sitewide-nav" class="topbar-style">
        <div class="container">
            <ul>
                {% for item in navigation.items %}
                    {# Items under dynamic rendering always have their active state
                    set by JS once the common template is downloaded. #}
                    <li{% if app.staticRender and item == navigation.getActiveItem() %} class="active"{% endif %}>
                        <a href="{{ item.href }}">
                            <span class="icon {{ item.icon }}"></span>
                            <span class="label" data-string="{{ item.title }}"></span>
                        </a>
                    </li>
                {% endfor %}
            </ul>
            <ul class="right">
                <li class="hide-if-noscript">
                    <button class="navigation-drawer-button">
                        <span class="icon navigation-drawer"
                            data-aria-label-string="sitewide_nav.navigation_drawer_label"></span>
                    </button>
                </li>
            </ul>
        </div>
    </nav>
{% endmacro %}