{# Template for index page. #}

{% import "macros.njk" as macros %}

<div class="content-container column-layout">
    <div class="column two-thirds">
        <div id="overview-column" class="module basic-module">
            <div class="module-header with-line">
                <h1 data-string="home_intro.hello"></h1>
            </div>
            <p data-string="home_intro.who"></p>
            <p data-string="home_intro.what"></p>
        </div>
        <div class="module projects-overview basic-module">
            <div class="module-header with-line">
                <h3 data-string="projects_overview.title"></h3>
            </div>
            <div>
                Recent work on projects (from GitHub) API will be shown here.
                This module will also display a nice lil loading placeholder
                because it will need to request that data from the GitHub API.
            </div>
        </div>
    </div>
    <div class="column one-third">
        {{ macros.mini_profile(
            subject_name="Leymonaide",
            avatar_url="//avatars.githubusercontent.com/u/230778645",
            link_url="/about",
            link_text="mini_profile.see_more_about_me",
            attributes={
                "data-thin-layout-merge-after": "#overview-column"
            }
        ) }}
        <div class="module blog-preview basic-module">
            <div class="module-header with-line">
                <h3 data-string="blog_preview.title"></h3>
            </div>
            <div>
                Recent blog posts will be shown here.
            </div>
        </div>
        {{ macros.site_footer_module() }}
    </div>
</div>